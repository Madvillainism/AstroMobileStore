---
const products: any[] = [];
import heroimg from "../assets/hero-1.png";
---

<section class="hero">
  <h1>Colección <strong>Divina</strong></h1>
  <img src={heroimg.src} alt="Imagen de la colección divina" />
  <p>
    Joyas y kits deportivos inspirados en la mitología japonesa combinada con la
    estética hip-hop urbano. Diseños exclusivos para destacar tu estilo único en
    cada ocasión.
  </p>
</section>

<section class="catalog-container">
  {
    products.length === 0 && (
      <div class="empty-state">
        <p>Próximamente: El catálogo se está cargando...</p>
      </div>
    )
  }

  <div class="product-grid">
    {products.map((product) => <article class="product-card" />)}
  </div>
</section>

<style>
  strong {
    color: var(--accent-crimson);
  }
  /* --- MOBILE FIRST LAYOUT (Default Phone Display) --- */
  .hero {
    text-align: center;
    padding: 3rem 1.5rem 1.5rem 1.5rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .hero p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .hero img {
    width: 100%;
    height: 70%;
    max-width: 600px;
  }

  .catalog-container {
    padding: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Structural Display Fallback */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    border: 2px dashed var(--border-color);
    border-radius: 12px;
    color: var(--text-muted);
  }

  /* Core Responsive Grid Layout Framework */
  .product-grid {
    display: grid;
    grid-template-columns: 1fr; /* 1 structural column on mobile devices */
    gap: 1.5rem;
  }

  /* --- TABLET SCREEN BREAKPOINT SCALE UP --- */
  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr); /* 2 balanced columns */
    }
    .hero h1 {
      font-size: 2.5rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .hero img {
      max-width: 500px;
    }
  }

  /* --- DESKTOP SCREEN BREAKPOINT SCALE UP --- */
  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr); /* 3 crisp structural columns */
      gap: 2rem;
    }
    .catalog-container {
      padding: 2rem 1rem;
    }

    .hero h1 {
      font-size: 3rem;
    }

    .hero p {
      font-size: 1.125rem;
    }

    .hero img {
      max-width: 400px;
    }
  }
</style>
